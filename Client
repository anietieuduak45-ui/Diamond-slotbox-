<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Diamond slotbox — Loading</title>
  <link rel="stylesheet" href="loading.css">
</head>
<body>
  <div class="loading-bg" id="loadingBg">
    <img src="assets/landing1.jpg" alt="Landing" class="hero" />
    <div class="overlay"></div>
    <div class="center-card">
      <div class="logo">Diamond slotbox</div>
      <div class="subtitle">Preparing your experience…</div>
      <div class="progress-wrap"><div class="progress-bar" id="progressBar"></div></div>
      <div class="small">New here? Sign up in a moment.</div>
    </div>
    <div class="footer-note">Loading assets • Initializing game engine</div>
  </div>
<script>
  const bg = document.getElementById('loadingBg');
  const hero = document.querySelector('.hero');
  if (hero.complete) bg.classList.add('loaded'); else hero.addEventListener('load', ()=> bg.classList.add('loaded'));
  let p=0; const bar=document.getElementById('progressBar');
  const interval=setInterval(()=>{ p+=Math.floor(Math.random()*12)+6; if(p>100)p=100; bar.style.width=p+'%'; if(p>=100){clearInterval(interval); setTimeout(()=>location.href='/client/index.html',700);} },300);
</script>
</body>
</html>
